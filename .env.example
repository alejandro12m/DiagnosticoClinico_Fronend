# Base URL de la API.
# - Dev (Vite): dejalo vacío y usá el proxy /api (ver vite.config.js)
# - Prod (Vercel): podés dejarlo vacío si usás el rewrite /api -> backend (ver vercel.json),
#   o setearlo a tu backend (ej: https://diagnosticoseguro2-3.onrender.com)
VITE_API_URL=

# Solo para vite.config (opcional): otro host de API en dev
# VITE_DEV_PROXY_TARGET=https://diagnosticoseguro2-3.onrender.com
